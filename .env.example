# MongoDB connection string (MongoDB Atlas recommended)
DATABASE_URL=mongodb+srv://<user>:<password>@cluster.mongodb.net/core_task

# URL of the deployed frontend (for CORS and email links)
FRONTEND_URL=http://localhost:5173

# SMTP credentials (e.g. Mailtrap for dev, SendGrid/Resend for prod)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# JWT secret — use a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret
